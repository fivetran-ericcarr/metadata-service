# Fivetran
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_GROUP_ID=
FIVETRAN_BASE_URL=https://api.fivetran.com/v1

# dbt Platform / dbt Cloud
DBT_ACCOUNT_ID=
DBT_SERVICE_TOKEN=
DBT_BASE_URL=https://cloud.getdbt.com/api
DBT_METADATA_API_URL=

# Storage
METADATA_STORAGE_BACKEND=local
METADATA_LOCAL_PATH=./metadata_snapshots
METADATA_S3_BUCKET=
METADATA_S3_PREFIX=metadata

# Service
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080

# MCP server (stdio for local agents; http/sse for hosted/remote agents)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Data Quality
# Warehouse type used when building object IDs (warehouse://db/schema/table).
# Set to `snowflake` to also enable the fivetran_metadata PK/lineage reader below.
WAREHOUSE_TYPE=warehouse
# Flag a Fivetran sync as stale if last_successful_sync is older than this many hours
STALE_SYNC_THRESHOLD_HOURS=24

# Warehouse metadata reader (optional) — reads authoritative PKs/lineage from the
# Fivetran Platform Connector's fivetran_metadata schema in the destination.
# Enabled when WAREHOUSE_TYPE=snowflake and account + database + an auth method are set.
# Install: pip install 'metadata-service[warehouse-snowflake]'
WAREHOUSE_ACCOUNT=
WAREHOUSE_USER=
WAREHOUSE_ROLE=
WAREHOUSE_NAME=
WAREHOUSE_DATABASE=
WAREHOUSE_METADATA_SCHEMA=fivetran_metadata
WAREHOUSE_PRIVATE_KEY_PATH=
WAREHOUSE_PASSWORD=

# --- Fivetran Activations (reverse ETL) readiness gate -------------------------
# Census-based Activations API. Set the workspace access token to enable the gate.
# Syncs are scoped to those reading WAREHOUSE_DATABASE (above).
ACTIVATIONS_API_TOKEN=
ACTIVATIONS_BASE_URL=https://app.getcensus.com/api/v1
